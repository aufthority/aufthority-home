  }
  .conclusion-item:last-child { border-bottom: none; }
  .conclusion-num {
    font-family: var(--serif);
    font-size: 1.8rem;
    color: var(--rule);
    line-height: 1;
    min-width: 40px;
    flex-shrink: 0;
  }
  .conclusion-body { font-size: 0.93rem; }
  .conclusion-body strong { display: block; margin-bottom: 4px; font-size: 0.97rem; }

  /* SVG chart container */
  .chart-wrap {
